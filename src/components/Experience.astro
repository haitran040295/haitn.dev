---
import SectionHeading from './SectionHeading.astro';

// PLACEHOLDER timeline — periods/roles are anonymized scaffolding. Replace the
// year ranges and titles with your real history before publishing.
const roles = [
  {
    period: '2023 — Now',
    role: 'Senior Fullstack Engineer',
    context: 'US SaaS company · remote',
    detail: 'Building Tenantly, a multi-tenant website builder, end-to-end.',
  },
  {
    period: '2021 — 2023',
    role: 'Fullstack Engineer',
    context: 'Product & client teams',
    detail: 'Shipped CRMs, storefronts, and sports-eligibility tooling on Next.js, React, and Go.',
  },
  {
    period: '2019 — 2021',
    role: 'Fullstack Engineer',
    context: 'Web & mobile',
    detail: 'Launched React Native apps and rebuilt high-traffic marketing sites for speed.',
  },
  {
    period: '2017 — 2019',
    role: 'Software Engineer',
    context: 'Early career',
    detail: 'Cut my teeth on large web platforms — SPAs, plugin frameworks, the parts that keep them running.',
  },
];
---

<section id="experience" aria-labelledby="experience-heading" class="py-16">
  <div class="mx-auto max-w-narrow px-4 sm:px-8">
    <SectionHeading
      id="experience-heading"
      eyebrow="EXPERIENCE"
      title="Eight years, hands-on"
      lead="Four chapters, one constant. I've stayed close to the code the whole way."
    />

    <ol class="timeline mt-12">
      {
        roles.map((r) => (
          <li class="timeline-item" data-timeline-item>
            <span class="timeline-node" aria-hidden="true" />
            <div class="timeline-content">
              <p class="timeline-period font-mono text-body-sm text-secondary">{r.period}</p>
              <h3 class="text-h4 font-display text-primary">{r.role}</h3>
              <p class="font-mono text-body-sm text-secondary">{r.context}</p>
              <p class="text-body text-secondary">{r.detail}</p>
            </div>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<script>
  const timeline = document.querySelector<HTMLElement>('.timeline');
  const items = Array.from(document.querySelectorAll<HTMLElement>('[data-timeline-item]'));

  if (timeline && items.length) {
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (reduce) {
      // No motion: show the finished state (full line, all nodes lit).
      timeline.classList.add('is-complete');
      items.forEach((item) => item.classList.add('is-active'));
    } else {
      timeline.classList.add('js-timeline');

      // Light each node + slide its content in as it reaches the focal line.
      const io = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-active');
              io.unobserve(entry.target);
            }
          }
        },
        { rootMargin: '0px 0px -40% 0px', threshold: 0 }
      );
      items.forEach((item) => io.observe(item));

      // Draw the accent line in step with scroll progress through the section.
      let ticking = false;
      const update = () => {
        const rect = timeline.getBoundingClientRect();
        const progress = (window.innerHeight * 0.6 - rect.top) / rect.height;
        timeline.style.setProperty('--timeline-progress', String(Math.max(0, Math.min(1, progress))));
        ticking = false;
      };
      update();
      window.addEventListener(
        'scroll',
        () => {
          if (!ticking) {
            ticking = true;
            requestAnimationFrame(update);
          }
        },
        { passive: true }
      );
      window.addEventListener('resize', update, { passive: true });
    }
  }
</script>

<style>
  .timeline {
    position: relative;
  }

  /* the rail + the accent fill that draws as you scroll */
  .timeline::before,
  .timeline::after {
    content: '';
    position: absolute;
    left: 5px;
    top: 0.45rem;
    bottom: 0.45rem;
    width: 2px;
  }
  .timeline::before {
    background-color: var(--color-border-default);
  }
  .timeline::after {
    background-color: var(--color-accent-default);
    transform-origin: top;
    transform: scaleY(var(--timeline-progress, 0));
    transition: transform 120ms linear;
  }
  .timeline.is-complete::after {
    transform: scaleY(1);
  }

  .timeline-item {
    position: relative;
    padding-left: 2.25rem;
    padding-bottom: 2.5rem;
  }
  .timeline-item:last-child {
    padding-bottom: 0;
  }

  .timeline-node {
    position: absolute;
    left: 0;
    top: 0.45rem;
    width: 12px;
    height: 12px;
    border-radius: 9999px;
    background-color: var(--color-bg-canvas);
    border: 2px solid var(--color-border-default);
    transition:
      border-color 300ms ease,
      background-color 300ms ease,
      transform 300ms ease;
  }
  .timeline-item.is-active .timeline-node,
  .timeline.is-complete .timeline-node {
    border-color: var(--color-accent-default);
    background-color: var(--color-accent-default);
    transform: scale(1.2);
  }

  .timeline-content {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  /* Entries slide in once JS drives the timeline; no-JS shows them statically. */
  .timeline.js-timeline .timeline-content {
    opacity: 0;
    transform: translateX(-12px);
    transition:
      opacity 600ms ease,
      transform 600ms cubic-bezier(0.2, 0.7, 0.2, 1);
  }
  .timeline.js-timeline .timeline-item.is-active .timeline-content {
    opacity: 1;
    transform: none;
  }
</style>
